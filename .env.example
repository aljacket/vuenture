# Copy to .env and fill in. NEVER commit .env.
# Only needed for running `npm run fetch-jobs` locally.
# In CI these are GitHub repository secrets — see README.

JSEARCH_KEY=your_rapidapi_jsearch_key
# Optional fallback key
FLYBY_KEY=

# Only required when running the scoring step locally and you want to
# exercise the Claude CLI path. In CI the `claude` CLI is installed and
# authed via CLAUDE_CODE_OAUTH_TOKEN.
CLAUDE_CODE_OAUTH_TOKEN=

{
  "name": "vuenture",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Personal Vue.js job-search dashboard with Claude-powered scoring",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "fetch-jobs": "node --env-file=.env scripts/fetchJobs.mjs",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
    "pinia": "^2.1.7",
    "vue": "^3.4.21"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.5.1",
    "autoprefixer": "^10.4.18",
    "postcss": "^8.4.36",
    "tailwindcss": "^3.4.1",
    "typescript": "~5.4.0",
    "vite": "^8.0.7",
    "vue-tsc": "^2.0.6"
  }
}
